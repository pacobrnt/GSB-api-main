{
  "info": {
    "name": "GSB API - Tests JWT",
    "description": "Collection pour tester l'authentification JWT et la sécurité des routes protégées par authMiddleware.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "visiteur_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "praticien_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Authentification",
      "item": [
        {
          "name": "Signup - Créer un compte",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Dupont\",\n  \"prenom\": \"Jean\",\n  \"email\": \"jean.dupont@gsb.fr\",\n  \"password\": \"Password123!\",\n  \"tel\": \"0612345678\",\n  \"date_embauche\": \"2023-01-15\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Crée un nouveau compte visiteur. Retourne un token JWT valide 24h."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.collectionVariables.set('visiteur_id', json.visiteur.id);",
                  "    console.log('✅ Token sauvegardé:', json.token);",
                  "}",
                  "pm.test('Status 201 - Compte créé', () => pm.response.to.have.status(201));",
                  "pm.test('Token présent dans la réponse', () => {",
                  "    pm.expect(pm.response.json()).to.have.property('token');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login - Se connecter (sauvegarde le token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jean.dupont@gsb.fr\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Connexion avec email/password. Le token JWT est automatiquement sauvegardé dans la variable {{token}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.collectionVariables.set('visiteur_id', json.visiteur.id);",
                  "    console.log('✅ Token sauvegardé:', json.token);",
                  "}",
                  "pm.test('Status 200 - Connexion réussie', () => pm.response.to.have.status(200));",
                  "pm.test('Token présent dans la réponse', () => {",
                  "    pm.expect(pm.response.json()).to.have.property('token');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login - Mauvais mot de passe (401)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jean.dupont@gsb.fr\",\n  \"password\": \"mauvais_motdepasse\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Doit retourner 401 si le mot de passe est incorrect."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 - Identifiants incorrects', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "🛡️ Tests Middleware JWT",
      "description": "Teste le comportement du authMiddleware sur les routes protégées.",
      "item": [
        {
          "name": "✅ Avec token valide - GET visiteurs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/visiteurs",
              "host": ["{{base_url}}"],
              "path": ["api", "visiteurs"]
            },
            "description": "Requête avec un token valide. Doit retourner 200."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Accès autorisé avec token valide', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "❌ Sans token - GET visiteurs (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/visiteurs",
              "host": ["{{base_url}}"],
              "path": ["api", "visiteurs"]
            },
            "description": "Requête SANS header Authorization. Doit retourner 401 si le middleware est appliqué."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 - Accès refusé sans token', () => pm.response.to.have.status(401));",
                  "pm.test('Message Unauthorized', () => {",
                  "    pm.expect(pm.response.json().error).to.equal('Unauthorized request');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "❌ Token invalide/expiré - GET visiteurs (401)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer token.invalide.ici" }
            ],
            "url": {
              "raw": "{{base_url}}/api/visiteurs",
              "host": ["{{base_url}}"],
              "path": ["api", "visiteurs"]
            },
            "description": "Requête avec un token forgé/invalide. Doit retourner 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 - Token invalide rejeté', () => pm.response.to.have.status(401));",
                  "pm.test('Message Unauthorized', () => {",
                  "    pm.expect(pm.response.json().error).to.equal('Unauthorized request');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "❌ Format Bearer manquant - GET visiteurs (401)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/visiteurs",
              "host": ["{{base_url}}"],
              "path": ["api", "visiteurs"]
            },
            "description": "Token sans le préfixe 'Bearer '. Doit retourner 401 car authHeader.split(' ')[1] sera undefined."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 - Format Bearer requis', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
