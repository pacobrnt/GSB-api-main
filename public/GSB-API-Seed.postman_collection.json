    {
      "name": "📋 5 - Créer les Visites",
      "description": "Crée 5 visites. Note: le validator attend visiteurId/praticienId/motifId/dateVisite, mais le controller lit visiteur/praticien/motif/date_visite — les deux jeux de noms sont envoyés.",
      "item": [
        {
          "name": "Visite 1 - Dupont chez Lefevre (motif 1)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"visiteurId\": \"{{visiteur1_id}}\",\n  \"visiteur\": \"{{visiteur1_id}}\",\n  \"praticienId\": \"{{praticien1_id}}\",\n  \"praticien\": \"{{praticien1_id}}\",\n  \"motifId\": \"{{motif1_id}}\",\n  \"motif\": \"{{motif1_id}}\",\n  \"dateVisite\": \"2026-01-10\",\n  \"date_visite\": \"2026-01-10\",\n  \"commentaire\": \"Présentation du médicament CardioPlus au Dr. Lefevre. Bonne réceptivité.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/visites",
              "host": ["{{base_url}}"],
              "path": ["api", "visites"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Visite 1 créée', () => pm.response.to.have.status(201));",
                  "console.log('✅ Visite 1:', pm.response.json().data?._id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
