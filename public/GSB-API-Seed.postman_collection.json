{
  "info": {
    "name": "GSB API - Seed BDD",
    "description": "Collection de jeu de données : supprime toutes les données existantes puis recrée des motifs, visiteurs, praticiens, visites et portefeuilles. Exécuter les dossiers dans l'ordre 0 → 5.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",     "value": "http://localhost:3000", "type": "string" },
    { "key": "token",        "value": "", "type": "string" },
    { "key": "visiteur1_id", "value": "", "type": "string" },
    { "key": "visiteur2_id", "value": "", "type": "string" },
    { "key": "visiteur3_id", "value": "", "type": "string" },
    { "key": "praticien1_id","value": "", "type": "string" },
    { "key": "praticien2_id","value": "", "type": "string" },
    { "key": "praticien3_id","value": "", "type": "string" },
    { "key": "motif1_id",    "value": "", "type": "string" },
    { "key": "motif2_id",    "value": "", "type": "string" },
    { "key": "motif3_id",    "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🗑️ 0 - Nettoyage BDD",
      "description": "Supprime toutes les données existantes. Exécuter chaque requête dans l'ordre.",
      "item": [
        {
          "name": "Supprimer toutes les visites",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/visites",
              "host": ["{{base_url}}"],
              "path": ["api", "visites"]
            },
            "description": "Récupère toutes les visites puis les supprime une par une via le script de test."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (!json.data || json.data.length === 0) {",
                  "    console.log('✅ Aucune visite à supprimer');",
                  "    return;",
                  "}",
                  "json.data.forEach(item => {",
                  "    pm.sendRequest({",
                  "        url: pm.collectionVariables.get('base_url') + '/api/visites/' + item._id,",
                  "        method: 'DELETE',",
                  "        header: { 'Authorization': 'Bearer ' + pm.collectionVariables.get('token') }",
                  "    }, (err, res) => {",
                  "        console.log('🗑️ Visite supprimée:', item._id, '| Status:', res.status);",
                  "    });",
                  "});",
                  "pm.test('Visites récupérées pour suppression: ' + json.data.length, () => true);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Supprimer tous les portefeuilles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/portefeuille",
              "host": ["{{base_url}}"],
              "path": ["api", "portefeuille"]
            },
            "description": "Récupère toutes les relations portefeuille puis les supprime."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (!json.data || json.data.length === 0) {",
                  "    console.log('✅ Aucun portefeuille à supprimer');",
                  "    return;",
                  "}",
                  "json.data.forEach(item => {",
                  "    const visiteurId = item.visiteur?._id || item.visiteur;",
                  "    const praticienId = item.praticien?._id || item.praticien;",
                  "    pm.sendRequest({",
                  "        url: pm.collectionVariables.get('base_url') + '/api/portefeuille/' + visiteurId + '/' + praticienId,",
                  "        method: 'DELETE',",
                  "        header: { 'Authorization': 'Bearer ' + pm.collectionVariables.get('token') }",
                  "    }, (err, res) => {",
                  "        console.log('🗑️ Portefeuille supprimé:', visiteurId, '/', praticienId, '| Status:', res.status);",
                  "    });",
                  "});",
                  "pm.test('Portefeuilles récupérés pour suppression: ' + json.data.length, () => true);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
